# ===========================
# 应用配置
# ===========================
APP_NAME=AI面试助手
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ===========================
# 数据库配置
# ===========================
DB_HOST=localhost
DB_PORT=3306
DB_USER=interview
DB_PASSWORD=interview123
DB_NAME=interview_assistant
DB_ROOT_PASSWORD=interview123
DATABASE_URL=mysql+pymysql://interview:interview123@localhost:3306/interview_assistant

# ===========================
# Redis 配置
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ===========================
# LLM 大模型配置(DeepSeek)
# ===========================
# DeepSeek API 密钥 - 请在 https://platform.deepseek.com/api_keys 获取
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# DeepSeek 思维链模式(面试场景建议开启，模型会先思考再回答)
LLM_THINKING_ENABLED=true
# 思考强度: high(默认)| max(增强 Agent 场景)
LLM_REASONING_EFFORT=high

# Embedding 模型
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

# ===========================
# 向量数据库配置
# ===========================
CHROMA_PERSIST_DIR=./chroma_db

# ===========================
# 语音识别配置
# ===========================
# DashScope（当前项目实际使用）
DASHSCOPE_API_KEY=
PARAFOUNDER_MODEL=paraformer-v2

# ===========================
# 文件上传配置
# ===========================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.mp3,.wav,.m4a,.ogg

# ===========================
# JWT 认证配置
# ===========================
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================
# 服务端口
# ===========================
BACKEND_PORT=8000
FRONTEND_PORT=80

# ===========================
# 前端配置
# ===========================
VITE_API_BASE_URL=/api

# ===========================
# TAVILY API 配置
# ===========================
TAVILY_API_KEY=your-tavily-api-key-here
